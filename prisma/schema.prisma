// Prisma schema for Uzinex admin module
// Single ContentBlock model holds all editable content as JSON

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContentBlock {
  key       String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

model AdminSession {
  token     String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ClientUser {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String
  company      String?
  phone        String?
  role         String          @default("client") // client | admin
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  sessions     ClientSession[]
}

model ClientSession {
  token     String     @id
  userId    String
  user      ClientUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime   @default(now())

  @@index([userId])
}
